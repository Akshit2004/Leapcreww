# NextAuth Configuration
NEXTAUTH_SECRET=""
NEXTAUTH_URL=""

# Platform administration
# Comma-separated emails allowed to perform cross-tenant platform-admin actions
# (e.g. provisioning white-label partners via POST /api/partner). Empty = nobody.
PLATFORM_ADMIN_EMAILS=""

# PostgreSQL Connection
DATABASE_URL=""
DIRECT_URL=""

# ─── WhatsApp Cloud API (System User Token Architecture) ─────────────────────
# Single System User Token from Meta Business Manager
# Generate in: Business Manager → System Users → Generate Token
# Required permissions: whatsapp_business_management, whatsapp_business_messaging
WHATSAPP_SYSTEM_USER_TOKEN=""

# Meta App Configuration
NEXT_PUBLIC_META_APP_ID=""
NEXT_PUBLIC_META_CONFIG_ID=""
META_APP_ID=""
META_APP_SECRET=""
META_BUSINESS_MANAGER_ID=""

# WhatsApp API
WHATSAPP_API_VERSION=""
WHATSAPP_APP_SECRET=""
WHATSAPP_WEBHOOK_VERIFY_TOKEN=""
NEXT_PUBLIC_SYSTEM_WHATSAPP_NUMBER=""

# Cron Job Authentication (required for /api/cron/process-broadcasts)
CRON_SECRET=""

# Groq API Configuration
GROQ_API_KEY=""

# Shopify webhook HMAC verification. Set to the same value as SHOPIFY_CLIENT_SECRET
# (the app's client secret from Shopify Partners). Webhooks are registered via the REST API
# during OAuth, so Shopify signs them with the app's client secret — not a per-store secret.
# Required in production: the Shopify webhook route rejects all traffic when unset.
SHOPIFY_WEBHOOK_SECRET=""
SHOPIFY_CLIENT_SECRET=""

# Razorpay Configuration
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# UploadThing Configuration
UPLOADTHING_TOKEN=""

# ─── Rate Limiting (Upstash Redis) ───────────────────────────────────────────
# Powers per-customer rate limiting in src/middleware.ts. OPTIONAL: when these
# are unset, rate limiting silently no-ops and all requests are allowed through.
# Create a database at https://console.upstash.com → REST API section.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# SMTP Configuration
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
