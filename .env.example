# NextAuth Configuration
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Platform administration
# Comma-separated emails allowed to perform cross-tenant platform-admin actions
# (e.g. provisioning white-label partners via POST /api/partner). Empty = nobody.
PLATFORM_ADMIN_EMAILS=""

# PostgreSQL Connection (Supabase IPv4 Pooler - Vercel compatible)
DATABASE_URL=""
DIRECT_URL=""

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Groq API Configuration
GROQ_API_KEY=""

# Razorpay Configuration
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# Cron Job Authentication
CRON_SECRET=""

# Integration secret encryption key (AES-256-GCM)
# Required to encrypt third-party access tokens at rest (Shopify, etc.).
# MUST be a 64-character hex string = 32 random bytes. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If unset, secrets are stored in PLAINTEXT (dev-only fallback). Set in prod.
INTEGRATION_TOKEN_KEY=""
# Legacy alias read as a fallback if INTEGRATION_TOKEN_KEY is unset.
SHOPIFY_TOKEN_KEY=""

# WhatsApp Cloud API (System User Token Architecture)
# Single System User Token from Meta Business Manager (never expires unless revoked)
WHATSAPP_SYSTEM_USER_TOKEN=""

# Meta App Configuration
NEXT_PUBLIC_META_APP_ID=""
NEXT_PUBLIC_META_CONFIG_ID=""
META_APP_ID=""
META_APP_SECRET=""
META_BUSINESS_MANAGER_ID=""

# WhatsApp API
WHATSAPP_API_VERSION="v25.0"
WHATSAPP_APP_SECRET=""
WHATSAPP_WEBHOOK_VERIFY_TOKEN=""
NEXT_PUBLIC_SYSTEM_WHATSAPP_NUMBER=""

# Shopify OAuth Integration Configuration
SHOPIFY_CLIENT_ID=""
SHOPIFY_CLIENT_SECRET=""

# UploadThing Configuration
UPLOADTHING_TOKEN=""

# Rate Limiting (Upstash Redis)
# Powers per-customer rate limiting in src/middleware.ts. OPTIONAL: when unset, rate limiting no-ops.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# SMTP Configuration
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
