datasource db {
  provider = "postgresql"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

model User {
  id                    String                 @id @default(uuid())
  name                  String?
  email                 String                 @unique
  hashedPassword        String?
  emailVerified         DateTime?
  image                 String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  phone                 String?                @unique
  whatsAppLoginAttempts WhatsAppLoginAttempt[]
  memberships           Membership[]
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // WhatsApp Business identifiers (per-org, stored after Embedded Signup)
  whatsappBusinessAccountId String?
  whatsappPhoneNumberId     String?
  metaBusinessId            String?
  metaCatalogId             String?
  whatsappConnected         Boolean @default(false)

  // Wallet & SaaS credits
  walletBalance Float @default(0.0)

  // Onboarding state
  onboardingDismissed Boolean @default(false)

  // Marketplace Bot state (legacy flag, kept in sync with activeUseCase)
  marketplaceBotEnabled Boolean @default(false)

  // Active WhatsApp use-case agent: "NONE" | "MARKETPLACE" | "APPOINTMENT".
  // Exactly one agent type is active at a time; switching deactivates the previous one.
  activeUseCase String @default("NONE")

  // Terminology preset for the appointment agent:
  // "HEALTHCARE" | "HOSPITALITY" | "EDUCATION" | "CORPORATE"
  appointmentPreset String @default("HEALTHCARE")

  // Chatbot Builder state
  chatbotBuilderEnabled Boolean @default(true)

  // Business vertical for sidebar nav filtering: "ECOMMERCE" | "APPOINTMENT" | "GENERAL"
  // Validated in app code (not a Prisma enum), to match activeUseCase's style via isValidUseCase-like guards.
  businessVertical String @default("GENERAL")

  // True once the org has completed the first-run "what's your business" picker
  useCaseOnboarded Boolean @default(false)

  // Org-level escape hatch: show all sidebar tabs regardless of businessVertical
  navShowAllTabs Boolean @default(false)

  // Brand-Aware AI content generation profile ({ name, industry, toneOfVoice })
  brandProfile Json?

  // Free-text business knowledge/FAQ/policies injected into the autoresponder AI system prompt
  aiKnowledgeBase String? @db.Text

  // Optional custom persona/tone instructions overriding the default sales-assistant persona
  aiPersona String? @db.Text

  // Groq sampling temperature for the free-form AI autoresponder agent
  aiTemperature Float? @default(0.7)

  // Merchant-configured Shopify discount code used by the T3 cart-recovery
  // incentive send. Must be a code the merchant already created in Shopify —
  // when null, the recovery pipeline sends a no-incentive template instead of
  // promising a discount it cannot honour.
  cartRecoveryDiscountCode String?

  // Opt-in: pause Shopify fulfillment on high-risk COD orders pending WhatsApp verification.
  // Requires shopify integration to be connected. False by default — merchants enable explicitly.
  fulfillmentHoldEnabled Boolean @default(false)

  // Opt-in: audit COD orders for risk even before WhatsApp is connected ("Silent Watcher").
  // Scores orders, tags them in Shopify, surfaces count in the onboarding dashboard.
  silentWatcherEnabled Boolean @default(false)

  // White-label / agency reseller link (T-09)
  partnerId String?
  partner   Partner? @relation(fields: [partnerId], references: [id], onDelete: SetNull)

  memberships          Membership[]
  contacts             Contact[]
  campaigns            Campaign[]
  templates            Template[]
  chatbotNodes         ChatbotNode[]
  integrations         Integration[]
  systemLogs           SystemLog[]
  messages             Message[]
  products             Product[]
  orders               Order[]
  // Roadmap relations
  ads                  Ad[]
  adCampaigns          AdCampaign[]
  flows                Flow[]
  flowResponses        FlowResponse[]
  sequences            Sequence[]
  sequenceEnrollments  SequenceEnrollment[]
  segments             Segment[]
  routingRules         RoutingRule[]
  usageEvents          UsageEvent[]
  apiKeys              ApiKey[]
  webhookSubscriptions WebhookSubscription[]
  attributionTouches   AttributionTouch[]
  appointmentSlots     AppointmentSlot[]
  bookings             Booking[]
  walletTopups         WalletTopup[]
  widgetConfig         WidgetConfig?
  stockAlerts          StockAlert[]
  launches             Launch[]
  ndrEvents            NdrEvent[]
  webhookDeliveries    WebhookDelivery[]
  idempotencyKeys      IdempotencyKey[]
  events               Event[]
  phoneNumbers         PhoneNumber[]
  workingHours         Json? // { enabled, timezone, schedule: { [day]: { open, from, to } }, awayMessage }
  cannedReplies        CannedReply[]
  internalNotes        InternalNote[]

  // Flow Encryption automation state
  flowsPrivateKey        String? @db.Text
  flowsPublicKeyUploaded Boolean @default(false)
}

enum Role {
  OWNER
  ADMIN
  AGENT
}

model Membership {
  id             String       @id @default(uuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           Role         @default(AGENT)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId, organizationId])
}

model Contact {
  id                  String               @id @default(uuid())
  name                String
  phone               String
  email               String?
  source              String
  tags                String[] // Postgres scalar list support
  status              String // "Active" | "Inactive"
  lastMessage         String?
  lastMessageTime     String?
  unreadCount         Int                  @default(0)
  assignedAgent       String               @default("None")
  currentNodeId       String? // Tracks position in chatbot flow tree
  conversationSummary String?              @db.Text // Rolling LLM-generated summary of older conversation history (long-chat context window management)
  attributes          Json? // Custom attributes (key/value) for segmentation (T-04)
  lastActiveAt        DateTime? // Last inbound activity, drives "active within N days" segments (T-04)
  organizationId      String
  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages            Message[]
  cart                Cart?
  orders              Order[]
  enrollments         SequenceEnrollment[]
  flowResponses       FlowResponse[]
  attributionTouches  AttributionTouch[]
  bookings            Booking[]
  internalNotes       InternalNote[]
  stockAlerts         StockAlert[]
  ndrEvents           NdrEvent[]
  sourceAdId          String? // Tracks the Meta Ad ID that originated this contact
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  // Contacts are tenant-scoped: a customer phone is unique within an org, never
  // globally. Prevents cross-tenant collision on shared customer phones.
  @@unique([organizationId, phone])
}

model Message {
  id             String       @id @default(uuid())
  sender         String // "user" | "agent" | "system"
  text           String       @db.Text
  status         String? // "sent" | "delivered" | "read"
  buttons        String[] // Postgres scalar list support
  contactId      String
  contact        Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  waMessageId    String? // WhatsApp API message ID for delivery tracking
  campaignId     String? // Links broadcast messages to a campaign for targeted log queries
  createdAt      DateTime     @default(now())
}

model Campaign {
  id           String  @id @default(uuid())
  name         String
  targetTag    String
  templateName String?
  flowId       String?
  flow         Flow?   @relation(fields: [flowId], references: [id], onDelete: SetNull)
  sent         Int     @default(0)
  delivered    Int     @default(0)
  read         Int     @default(0)
  clicked      Int     @default(0)
  status       String // "Completed" | "Active" | "Scheduled" | "Sending"
  date         String

  // New scheduling & media fields
  scheduledAt    DateTime?
  excludeTag     String?
  mediaType      String? // "image" | "video" | "document" | "none"
  mediaUrl       String?
  variables      Json?
  delay          Int?         @default(1)
  currentOffset  Int          @default(0) // queue engine: contacts processed so far
  segmentId      String? // Target a saved segment instead of a single tag (T-04)
  segment        Segment?     @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  timezone       String? // IANA tz for timezone-aware scheduling (T-11)
  recurrence     String? // null | "daily" | "weekly" | "monthly" (T-11)
  leadQualifier  Json? // LeadQualifierConfig — intercept handler config for post-CTA qualification flows
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
}

model Template {
  id             String       @id @default(uuid())
  name           String
  body           String       @db.Text
  category       String // "Marketing" | "Utility" | "Authentication"
  buttons        String[] // Postgres scalar list support
  mediaType      String       @default("none") // "none" | "image" | "video" | "document"
  mediaUrl       String? // sample media for the optional header (image/video/document)
  metaStatus     String       @default("pending") // "pending" | "approved" | "rejected"
  metaId         String? // Meta template ID for status polling
  isShared       Boolean      @default(false) // visible to all orgs
  flowId         String?
  flow           Flow?        @relation(fields: [flowId], references: [id], onDelete: SetNull)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
}

model ChatbotNode {
  id             String // Keep visual IDs: n1, n2, n3...
  type           String // "trigger" | "message" | "question" | "delay"
  title          String
  content        String       @db.Text
  options        String[] // Postgres scalar list
  delayTime      Int?
  nextId         String?
  routes         Json? // Stores options routing dynamically
  flowId         String?
  flow           Flow?        @relation(fields: [flowId], references: [id], onDelete: SetNull)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@id([id, organizationId])
}

model Integration {
  id             String // shopify, woocommerce, gsheets etc
  name           String
  description    String       @db.Text
  status         String // "connected" | "disconnected"
  icon           String
  apiKey         String?      @db.Text
  webhookUrl     String?      @db.Text
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@id([id, organizationId])
}

model SystemLog {
  id             String       @id @default(uuid())
  type           String // "campaign" | "chat" | "integration" | "crm"
  message        String       @db.Text
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaignId     String? // Links log to a campaign for precise filtering in reports
  createdAt      DateTime     @default(now())
}

// Pre-launch waitlist — public capture, intentionally not org-scoped.
model WaitlistEntry {
  id            String   @id @default(uuid())
  email         String   @unique
  brandName     String?
  monthlyOrders String? // self-reported band: "<500" | "500-2000" | "2000-10000" | "10000+"
  source        String   @default("landing") // "landing" | "calculator" | "vs_page"
  createdAt     DateTime @default(now())

  @@index([createdAt])
}

model Product {
  id             String       @id @default(uuid())
  sku            String?      @unique
  name           String
  description    String       @db.Text
  price          Int // in paise (₹100 = 10000)
  images         String[]
  category       String
  stock          Int          @default(0)
  isActive       Boolean      @default(true)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  cartItems      CartItem[]
  orderItems     OrderItem[]
}

model Cart {
  id        String     @id @default(uuid())
  contactId String
  contact   Contact    @relation(fields: [contactId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([contactId])
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
}

model Order {
  id                String      @id @default(uuid())
  orderId           String      @unique
  contactId         String
  contact           Contact     @relation(fields: [contactId], references: [id])
  items             OrderItem[]
  total             Int
  status            String      @default("pending") // "pending" | "confirmed" | "processing" | "shipped" | "delivered" | "cancelled"
  paymentStatus     String      @default("pending") // "pending" | "paid" | "failed" | "refunded"
  codStatus         String? // null = prepaid; "pending" | "confirmed" | "cancelled" for COD orders
  razorpayOrderId   String?     @unique
  razorpayPaymentId String?
  razorpaySignature String?
  address           Json?
  phone             String

  // Conversion attribution (D-04) — stamped at order creation via last-touch resolution
  attributedCampaignId String? // last campaign touch within window at order time
  attributedSequenceId String? // last sequence touch within window at order time
  attributedAgent      String? // snapshot of contact.assignedAgent at order time

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  shopifyNumericId  String? // raw Shopify numeric order ID (payload.id) for Admin API calls
  fulfillmentHoldId String? // Shopify fulfillment order ID currently on hold
  fulfillmentHeldAt DateTime? // when the hold was placed — cron auto-releases after 4h
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  name      String
  price     Int
  quantity  Int
}

// Appointment Booking use-case agent. AppointmentSlot is pure availability
// inventory (doctor, table, interviewer, service desk — label depends on the
// org's appointmentPreset). Payment is collected offline; `price` is purely
// informational ("pay at venue"). A slot is claimed atomically via `isBooked`;
// the customer-facing booking record lives in `Booking`.
model AppointmentSlot {
  id              String       @id @default(uuid())
  serviceName     String // preset-dependent label: doctor / table / interviewer / agent
  startTime       DateTime
  durationMinutes Int          @default(30)
  price           Int          @default(0) // in paise; 0 = free, >0 = fee shown to customer (pay at venue)
  isBooked        Boolean      @default(false)
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bookings        Booking[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Prevents duplicate slots and powers the recurring generator's skipDuplicates.
  @@unique([organizationId, serviceName, startTime])
  @@index([organizationId, isBooked, startTime])
}

// A customer's claim on a slot. Persists across cancellation (status="cancelled")
// so the merchant's bookings list keeps history while the slot reopens
// (isBooked=false). serviceName/startTime/price are snapshotted so the record
// survives slot edits or deletion.
model Booking {
  id             String           @id @default(uuid())
  slotId         String?
  slot           AppointmentSlot? @relation(fields: [slotId], references: [id], onDelete: SetNull)
  serviceName    String // snapshot of slot.serviceName at booking time
  startTime      DateTime // snapshot of slot.startTime at booking time
  price          Int              @default(0) // snapshot of slot.price (paise)
  bookingForName String // who the booking is for (patient / guest / student)
  status         String           @default("booked") // "booked" | "completed" | "no_show" | "cancelled"
  contactId      String
  contact        Contact          @relation(fields: [contactId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([organizationId, status, startTime])
  @@index([organizationId, contactId])
  @@index([slotId])
}

model WhatsAppLoginAttempt {
  id        String   @id @default(uuid())
  code      String   @unique // e.g. WPF-JDOZCFKTJRWI5
  otp       String? // 6-digit OTP for fallback
  phone     String? // Target phone number if entered for OTP
  status    String   @default("PENDING") // "PENDING" | "VERIFIED" | "VERIFIED_NEW_USER" | "EXPIRED"
  attempts  Int      @default(0) // wrong-OTP guesses; attempt is locked at >= 5
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime
}

model ChatbotAnalytics {
  id             String   @id @default(uuid())
  nodeId         String
  contactId      String
  action         String // "impression" | "response" | "dropoff"
  organizationId String
  createdAt      DateTime @default(now())
}

// ─── Roadmap models (see docs/PRODUCT_COMPARISON_AISENSY.md) ──────────────────

// T-01 — Click-to-WhatsApp Ads
model AdCampaign {
  id             String       @id @default(uuid())
  name           String
  objective      String       @default("LEADS") // Meta campaign objective
  budget         Float        @default(0.0) // daily budget in float units (from master)
  budgetMinor    Int          @default(0) // daily budget in minor units
  status         String       @default("draft") // "draft" | "active" | "paused" | "completed"
  metaCampaignId String? // Meta Marketing API campaign id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ads            Ad[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Ad {
  id              String  @id @default(uuid())
  name            String  @default("") // from master
  status          String  @default("draft") // "draft" | "active" | "paused" (unified)
  creative        Json? // from master (headline, primaryText, imagePrompt, imageUrl)
  ctwaClid        String? // Click-to-WhatsApp Click ID or unique reference
  linkedTemplate  String? // from master
  welcomeTemplate String? // from HEAD

  headline    String  @default("")
  primaryText String  @default("") @db.Text
  imageUrl    String?
  metaAdId    String?
  leads       Int     @default(0)

  adCampaignId   String?
  adCampaign     AdCampaign?  @relation(fields: [adCampaignId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// T-02 — WhatsApp Flows & Forms
model Flow {
  id             String         @id @default(uuid())
  name           String
  category       String         @default("LEAD_GENERATION") // Meta flow category
  flowJson       Json // Meta Flow JSON definition
  metaFlowId     String?
  status         String         @default("draft") // "draft" | "published"
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  templates      Template[]
  chatbotNodes   ChatbotNode[]
  campaigns      Campaign[]
  responses      FlowResponse[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model FlowResponse {
  id             String       @id @default(uuid())
  flowId         String
  flow           Flow         @relation(fields: [flowId], references: [id], onDelete: Cascade)
  contactId      String
  contact        Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  submittedData  Json
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
}

// T-03 — Drip / Sequence / Journey automation
model Sequence {
  id             String               @id @default(uuid())
  name           String
  trigger        String // "tag_added" | "form_submit" | "ad_click" | "cart_abandoned" | "signup"
  triggerConfig  Json? // e.g. { tag: "vip" }
  status         String               @default("active") // "active" | "paused"
  organizationId String
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  steps          SequenceStep[]
  enrollments    SequenceEnrollment[]
  segmentId      String?
  segment        Segment?             @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
}

model SequenceStep {
  id           String   @id @default(uuid())
  sequenceId   String
  sequence     Sequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  order        Int // 0-based position
  delayMinutes Int      @default(0) // wait before running this step
  actionType   String   @default("send_template") // "send_template" | "send_message" | "add_tag" | "branch"
  templateName String?
  message      String?  @db.Text
  conditions   Json? // optional gate, e.g. { ifNoReply: true }
  createdAt    DateTime @default(now())
}

model SequenceEnrollment {
  id             String       @id @default(uuid())
  sequenceId     String
  sequence       Sequence     @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  contactId      String
  contact        Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  currentStep    Int          @default(0)
  status         String       @default("active") // "active" | "completed" | "cancelled" | "failed"
  nextRunAt      DateTime? // cron wakes enrollments due now
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([nextRunAt, status])
}

// T-04 — Smart segments
model Segment {
  id             String       @id @default(uuid())
  name           String
  rules          Json // { all: [{ field, op, value }], any: [...] }
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sequences      Sequence[]
  campaigns      Campaign[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// T-05 — Multi-agent routing
model RoutingRule {
  id             String       @id @default(uuid())
  name           String
  condition      Json // { field, op, value } evaluated against inbound contact
  assignTo       String // membershipId / "round_robin" / team key
  priority       Int          @default(0)
  enabled        Boolean      @default(true)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
}

// T-06 — Conversation billing & cost ledger
model UsageEvent {
  id             String       @id @default(uuid())
  type           String // "message" | "template" | "conversation"
  category       String? // "marketing" | "utility" | "authentication" | "service"
  units          Int          @default(1)
  costMinor      Int          @default(0) // charged amount in minor currency units
  campaignId     String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([organizationId, createdAt])
}

// T-08 — Public Project API + webhooks
model ApiKey {
  id             String       @id @default(uuid())
  name           String
  hashedKey      String       @unique
  prefix         String // non-secret display prefix, e.g. "wf_live_ab12"
  scopes         String[]
  lastUsedAt     DateTime?
  revokedAt      DateTime?
  isSandbox      Boolean      @default(false)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
}

model WebhookSubscription {
  id             String            @id @default(uuid())
  url            String            @db.Text
  events         String[] // "message.received" | "message.status" | "order.placed" | ...
  secret         String // HMAC signing secret
  enabled        Boolean           @default(true)
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deliveries     WebhookDelivery[]
  createdAt      DateTime          @default(now())
}

// Outbound webhook delivery attempts (T-08). A row is created per matching
// subscription on emit, tried immediately, then retried by cron with
// exponential backoff until delivered or attempts are exhausted.
model WebhookDelivery {
  id             String              @id @default(uuid())
  subscriptionId String
  subscription   WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  event          String
  payload        Json
  status         String              @default("pending") // "pending" | "delivered" | "failed"
  attempts       Int                 @default(0)
  lastError      String?
  nextAttemptAt  DateTime            @default(now())
  deliveredAt    DateTime?
  organizationId String
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime            @default(now())

  @@index([status, nextAttemptAt])
}

// Public API idempotency (T-08): replaying a request with the same
// Idempotency-Key header returns the stored response instead of re-executing.
model IdempotencyKey {
  id             String       @id @default(uuid())
  key            String
  response       Json
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([organizationId, key])
  @@index([createdAt])
}

// Append-only domain event log — immutable audit trail for all significant
// business events. Consumers fan-out to webhooks, analytics, and replays.
model Event {
  id             String       @id @default(uuid())
  type           String // "message.received" | "message.status" | "order.placed" | "contact.created"
  payload        Json
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([organizationId, createdAt])
  @@index([organizationId, type, createdAt])
}

// Embeddable website chat-button widget (one per org). `publicKey` is the only
// identifier exposed on customer websites — never the org id. The phone number
// is stored here (E.164 digits) because Organization only keeps Meta's internal
// phoneNumberId, and the wa.me deep link needs the dialable number.
model WidgetConfig {
  id             String       @id @default(uuid())
  publicKey      String       @unique // "wfw_<hex>" — embed snippet identifier
  enabled        Boolean      @default(true)
  phoneNumber    String       @default("") // digits only, e.g. "919876543210"
  position       String       @default("bottom-right") // "bottom-right" | "bottom-left"
  color          String       @default("#25D366")
  greeting       String       @default("Hi there 👋 How can we help?")
  prefilledText  String       @default("Hi! I have a question.")
  showGreeting   Boolean      @default(true)
  clicks         Int          @default(0) // lifetime button-click counter
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// T-09 — White-label / partner / agency
model Partner {
  id            String         @id @default(uuid())
  name          String
  slug          String         @unique
  logoUrl       String?
  primaryColor  String?
  customDomain  String?        @unique
  pricingMarkup Float          @default(0.0) // multiplier applied over base conversation cost
  organizations Organization[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

// D-04 — Conversion-first analytics: last-touch attribution trail.
// One row per outbound marketing send (campaign or sequence step) to a contact.
// resolveAttribution() reads the latest row within a window to stamp Orders.
model AttributionTouch {
  id             String       @id @default(uuid())
  contactId      String
  contact        Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  channel        String // "campaign" | "sequence"
  campaignId     String?
  sequenceId     String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([contactId, createdAt])
  @@index([organizationId, createdAt])
}

// P1-6 — Team inbox: pre-written agent responses (inserted via /shortcut)
model CannedReply {
  id             String       @id @default(uuid())
  shortcut       String // e.g. "thanks" — agent types /thanks to insert
  title          String
  body           String       @db.Text
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([organizationId])
}

// P1-6 — Team inbox: agent-only notes on a conversation, never sent to customer
model InternalNote {
  id             String       @id @default(uuid())
  body           String       @db.Text
  authorName     String
  contactId      String
  contact        Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([contactId])
}

// P1-11 — Multi-number: each org can have N registered WhatsApp phone numbers
model PhoneNumber {
  id                        String       @id @default(uuid())
  displayName               String
  phoneNumber               String // dialable E.164 digits, e.g. "919876543210"
  phoneNumberId             String // Meta's internal phone number ID
  whatsappBusinessAccountId String?
  accessToken               String?      @db.Text
  isDefault                 Boolean      @default(false)
  organizationId            String
  organization              Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt

  @@unique([organizationId, phoneNumberId])
  @@index([organizationId])
}

model EmailOtpAttempt {
  id        String   @id @default(uuid())
  email     String
  otp       String
  status    String   @default("PENDING") // "PENDING" | "VERIFIED" | "EXPIRED"
  createdAt DateTime @default(now())
  expiresAt DateTime
}

// Back-in-stock alert registration.
// A customer supplies their phone on a sold-out product page; LeapCrew
// WhatsApps them the moment inventory comes back.
model StockAlert {
  id                     String       @id @default(uuid())
  organizationId         String
  organization           Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  phone                  String
  contactId              String?
  contact                Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  // Product identification — at least one must be set
  shopifyInventoryItemId String? // Shopify inventory_item_id (numeric string)
  sku                    String? // Generic identifier for non-Shopify platforms
  productTitle           String
  productUrl             String?
  isNotified             Boolean      @default(false)
  notifiedAt             DateTime?
  createdAt              DateTime     @default(now())

  @@index([organizationId, shopifyInventoryItemId, isNotified])
  @@index([organizationId, sku, isNotified])
  @@index([organizationId, phone])
}

// Flash Sale / Launch Countdown — a time-boxed broadcast campaign with
// auto-generated countdown steps (D-3, D-1, 5-min, Go Live, Last Chance).
// The cron worker `process-launch-steps` fires each step at its computed sendAt.
model Launch {
  id             String       @id @default(uuid())
  name           String
  description    String?
  productUrl     String?
  launchAt       DateTime
  status         String       @default("draft") // "draft" | "scheduled" | "ended"
  targetTag      String? // tag of contacts to broadcast to; null = all contacts
  steps          LaunchStep[]
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, status])
}

model LaunchStep {
  id             String   @id @default(uuid())
  launchId       String
  launch         Launch   @relation(fields: [launchId], references: [id], onDelete: Cascade)
  label          String
  offsetMinutes  Int // negative = before launchAt, 0 = at launch, positive = after
  message        String   @db.Text
  sendAt         DateTime // computed: launchAt + offsetMinutes
  status         String   @default("pending") // "pending" | "sent" | "skipped"
  sentCount      Int      @default(0)
  organizationId String

  @@index([status, sendAt])
  @@index([launchId])
}

// NDR (Non-Delivery Report) — tracks failed delivery attempts from couriers.
// When a courier files an NDR the brand contacts the customer on WhatsApp to
// confirm availability, reschedule, update address, or accept RTO. The status
// field captures the outcome: "pending" → one of confirmed / rescheduled /
// address_updated / cancelled / resolved.
model NdrEvent {
  id              String       @id @default(uuid())
  awb             String // Airway Bill number from courier
  orderId         String? // merchant order ID
  courier         String? // e.g. "Delhivery", "Shiprocket", "Bluedart"
  attempt         Int          @default(1)
  reason          String? // NDR reason from courier, e.g. "Customer not available"
  status          String       @default("pending")
  // status values: "pending" | "confirmed" | "rescheduled" | "address_updated" | "cancelled" | "resolved"
  customerPhone   String
  customerName    String?
  rescheduledDate String? // customer-provided reschedule date string
  updatedAddress  String? // customer-provided updated address
  contactId       String?
  contact         Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  resolvedAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, awb])
  @@index([contactId])
}

/// Shared RTO fraud network — the cross-merchant moat.
/// Each row is a single anonymized risk signal keyed by sha256(phone). Raw PII
/// is NEVER stored. `organizationId` records which brand reported the signal so
/// a brand can read its OWN history for a customer; it is deliberately a plain
/// String (no relation/cascade) so network signals survive even if the
/// reporting org is deleted — the anonymized dataset is the network's value.
model NetworkSignal {
  id             String   @id @default(uuid())
  phoneHash      String // sha256(normalized phone) — never raw PII
  signal         String // "rto" | "token_unpaid" | "cod_cancel" | "ndr_2plus"
  category       String? // product category, e.g. "fashion" | "electronics"
  organizationId String // reporting brand (internal only; never exposed cross-merchant)
  createdAt      DateTime @default(now())

  @@index([phoneHash])
  @@index([organizationId, phoneHash])
}

model WalletTopup {
  id              String       @id @default(uuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  amount          Float
  status          String       @default("pending") // "pending" | "paid" | "failed"
  razorpayOrderId String       @unique
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([organizationId])
}
